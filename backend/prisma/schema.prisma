 
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}


//define schema


model User{
  id    String  @id  @default(uuid())
  email String 
  provider   AuthProvider
  name    String
  conversations  Conversation[]
}

model Conversation{
    id    String  @id  @default(uuid())
    title  String?
    slug   String
    userId  String
    message Message[]
    user     User    @relation(fields: [userId], references: [id])
}

model Message{
    id    String  @id  @default(uuid())
    content String
    role    MessageRole
    conversationId String
    conversation  Conversation @relation(fields: [conversationId],references: [id])
    createdAt    DateTime   @default(now())
    
    
}
enum AuthProvider{
  google
  github
}

enum MessageRole{
    user
    assistant
}